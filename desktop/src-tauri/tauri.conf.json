{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AI Launcher",
  "version": "0.3.0",
  "identifier": "com.ailauncher.desktop",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "AI Launcher",
        "width": 1100,
        "height": 750,
        "minWidth": 20,
        "minHeight": 40,
        "resizable": true,
        "center": true,
        "decorations": false,
        "fullscreen": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$APPLOCALDATA/**",
          "$LOCALAPPDATA/**",
          "C:\\ai-launcher-data\\**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
